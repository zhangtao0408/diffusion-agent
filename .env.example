# LLM Provider: "openai", "anthropic", or "local"
DA_LLM_PROVIDER=openai

# Model name (e.g., gpt-4o, claude-sonnet-4-20250514, etc.)
DA_LLM_MODEL=gpt-4o

# API key for the chosen provider
DA_LLM_API_KEY=

# Base URL for local/vLLM deployments (optional)
DA_LLM_BASE_URL=

# Logging level: DEBUG, INFO, WARNING, ERROR
DA_LOG_LEVEL=INFO

# Working directory for cloned repos and workspace
DA_WORK_DIR=./workspace
